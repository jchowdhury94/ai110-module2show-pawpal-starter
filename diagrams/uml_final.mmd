classDiagram
    class Pet {
        +string name
        +string species
        +int age
        +list needs
        +list tasks
        +update_pet_info()
        +add_task(task)
        +remove_task(description)
        +complete_task(description)
        +get_tasks(completed)
        +get_summary()
    }

    class Task {
        +string description
        +string time
        +string frequency
        +bool completed
        +date due_date
        +date last_completed
        +Pet pet
        +mark_complete()
        +mark_incomplete()
        +is_due(reference_date)
        +update_task(description, time, frequency)
        +get_summary()
    }

    class Owner {
        +string available_time
        +list preferred_times
        +list task_priorities
        +list pets
        +update_preferences()
        +add_pet(pet)
        +remove_pet(name)
        +get_pet(name)
        +get_all_tasks(pet_name, completed)
    }

    class Scheduler {
        +Owner owner
        +date date
        +list selected_tasks
        +string explanation
        +list conflicts
        +list unparsed_tasks
        +generate_plan(pet_name, completed)
        +find_conflicts()
        +get_conflict_warnings()
        +show_plan()
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : has
    Task "*" --> "1" Pet : belongs to
    Scheduler "1" --> "1" Owner : uses
    Scheduler "1" --> "*" Task : selects
